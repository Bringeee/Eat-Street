# # Firebase Configuration for Reviews
# # Copy this to .env.local and fill in your Firebase config values
# # NEVER commit .env.local - keep your secrets safe!

# # Your Firebase API Key
# # Get from: Firebase Console → Project Settings → General → Web app config
# VITE_FIREBASE_API_KEY=your-api-key-here

# # Your Firebase Auth Domain
# # Format: your-project-id.firebaseapp.com
# VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# # Your Firebase Project ID
# # Get from: Firebase Console → Project Settings → General
# VITE_FIREBASE_PROJECT_ID=your-project-id

# # Your Firebase Storage Bucket
# # Format: your-project-id.appspot.com
# VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# # Your Firebase Messaging Sender ID
# # Get from: Firebase Console → Project Settings → General
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# # Your Firebase App ID
# # Get from: Firebase Console → Project Settings → General
# VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef


