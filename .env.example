# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local - keep your secrets safe!

# Your Supabase project URL
# Get this from: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon public key
# Get this from: Supabase Dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# NEVER use service_role key in frontend code!
# Service role key should only be used in backend/edge functions
# VITE_SUPABASE_SERVICE_ROLE_KEY=never-in-frontend

# Razorpay Configuration
# Get your key from: Razorpay Dashboard → Settings → API Keys
# Use test mode key for development (starts with rzp_test_)
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id-here

# Server-only secret (NO VITE_ prefix — never exposed to the browser)
# Used to create orders and verify payment signatures on the server
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here
